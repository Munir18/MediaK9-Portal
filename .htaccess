Options -Indexes
RewriteEngine On

# ── Block direct access to sensitive utility/dev files ─────────────
RewriteRule ^(install|pack|scratch-db-check|build-preview|local-router)\.php$ - [F,L]

# ── Route API and assets directly ─────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ api/$1 [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^assets/(.*)$ assets/$1 [L]

# ── Block all direct upload access ────────────────────────────────
RewriteRule ^uploads/.*$ - [F,L]

# ── Route everything else through index.php ────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# ── Security Headers ───────────────────────────────────────────────
<IfModule mod_headers.c>
    # Strict Transport Security (HTTPS only, 1 year)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # Prevent clickjacking
    Header always set X-Frame-Options "DENY"

    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Referrer policy (don't leak portal URL to external sites)
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions policy (disable unused browser features)
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"

    # Content Security Policy
    # Allows: self, Google Fonts (loaded by head.php), inline styles/scripts (needed for portal JS)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/; frame-src 'self' https://www.google.com/recaptcha/ https://recaptcha.google.com/recaptcha/; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"

    # Remove PHP version header
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>
